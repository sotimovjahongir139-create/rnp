# Server
PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=change_this_to_a_strong_secret
JWT_EXPIRES_IN=8h

# Analytics DB (central)
ANALYTICS_DB_HOST=localhost
ANALYTICS_DB_PORT=3306
ANALYTICS_DB_USER=rnp_user
ANALYTICS_DB_PASS=change_this_password
ANALYTICS_DB_NAME=rnp_analytics

# Production MySQL (read-only, phpMyAdmin)
PROD_DB_HOST=your_production_host
PROD_DB_PORT=3306
PROD_DB_USER=readonly_user
PROD_DB_PASS=readonly_password
PROD_DB_NAME=production_db

# AmoCRM (Python skriptlarda ham ishlatiladi)
AMOCRM_DOMAIN=yourcompany.amocrm.ru
AMOCRM_ACCESS_TOKEN=your_long_lived_token
# TARGET_MANAGERS filtri (vergul bilan ajratilgan)
AMOCRM_TARGET_MANAGERS=Asadbek

# CORS
CORS_ORIGIN=http://localhost:3000
